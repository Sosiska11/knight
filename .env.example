# Telegram Bot Configuration
BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ
ADMIN_TG_IDS=123456789,987654321

# YooKassa Payment Provider Token (get it from @BotFather -> Bot Settings -> Payments)
# For testing, use the test provider token provided by YooKassa via BotFather
YOOKASSA_TOKEN=123456789:TEST:12345

# 3x-ui Panel Configuration
XUI_URL=http://your-server-ip:2053
XUI_USERNAME=admin
XUI_PASSWORD=your_secure_password
XUI_INBOUND_ID=1
XUI_LIMIT_IP=1

# Set to true only if your 3x-ui panel uses a self-signed/mismatched TLS certificate.
# Leaving this unset/false keeps TLS verification enabled for security.
XUI_TLS_SKIP_VERIFY=false

# Run in Mock mode for testing without a real 3x-ui panel (true/false)
MOCK_XUI=true

# Database path
DATABASE_FILE=./database.db

# Subscription Server Settings
SUB_SERVER_URL=http://your-server-ip:3000
SUB_PORT=3000

# Set to true if the subscription server runs behind a trusted reverse proxy
# (nginx, Cloudflare, etc.) so rate limiting uses the real client IP.
# Leave false if the server is exposed directly to the internet.
TRUST_PROXY=false

# CDN Whitelist Bypass Configuration
XUI_CDN_INBOUND_ID=4
USE_CDN_BYPASS=false
CDN_DOMAIN=cdn.gamelightcoop.fun
CDN_PATH=/api/uploadFile
CDN_PORT=443
XHTTP_PATH=/api/uploadFile
XHTTP_MODE=packet-up

